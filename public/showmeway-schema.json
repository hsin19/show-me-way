{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "下面一way 行程 Schema",
  "type": "object",
  "required": ["trip", "days"],
  "properties": {
    "trip": {
      "type": "object",
      "required": ["name", "start", "end", "departure", "hotels"],
      "properties": {
        "name": {
          "type": "string",
          "description": "行程名稱"
        },
        "start": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "出發日期 (YYYY-MM-DD 格式，例如: 2026-06-11)"
        },
        "end": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "回程日期 (YYYY-MM-DD 格式，例如: 2026-06-16)"
        },
        "departure": {
          "type": "string",
          "description": "去程班機起飛時間，ISO 8601 格式，例如: 2026-06-11T14:00:00+08:00 (用於首頁倒數計時)"
        },
        "lang": {
          "type": "string",
          "enum": ["ko", "ja", "en"],
          "description": "目的地語言代碼，用於選擇內建的實用常用語與計程車司機提示 (ko=韓文, ja=日文, en=英文)。未設定或不支援時預設為英文 (en)。"
        },
        "currency": {
          "type": "string",
          "description": "記帳功能使用的貨幣代碼 (例如: KRW, JPY, USD)。未設定時預設為 TWD。"
        },
        "mapProvider": {
          "type": "string",
          "enum": ["naver", "google"],
          "description": "地圖搜尋使用的服務 (選填)。韓國因地圖法規建議設 naver，未設定時預設使用 Google Maps。"
        },
        "city": {
          "type": "string",
          "description": "目的地城市，用於查詢每日天氣預報 (選填，未設定或留空字串時不顯示天氣)。建議使用英文名稱 (例如: Tokyo, Seoul, Osaka)；中文名稱僅部分可查 (東京、京都可，首爾、大阪、釜山等查不到或比對錯國家)。同名城市可加兩碼國碼後綴消歧 (例如: 'Springfield, US')。可在個別 day 以 city 覆蓋 (多城市行程)。"
        },
        "wallets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "記帳使用的自訂電子錢包/卡片清單 (例如: Suica, WOWPASS, 信用卡。現金預設會自動存在)"
        },
        "hotels": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "address", "checkIn", "checkOut"],
            "properties": {
              "name": {
                "type": "string",
                "description": "飯店/旅宿名稱"
              },
              "address": {
                "type": "string",
                "description": "飯店外文地址 (供計程車司機觀看/複製)"
              },
              "checkIn": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                "description": "入住日期 (YYYY-MM-DD)"
              },
              "checkOut": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                "description": "退房日期 (YYYY-MM-DD)"
              },
              "localName": {
                "type": "string",
                "description": "地點的當地語言名稱，作為地圖搜尋關鍵字 (點擊按鈕開啟地圖/複製)"
              },
              "mapLink": {
                "type": "string",
                "description": "地圖直接連結 (如 naver.me / maps.app.goo.gl 短網址)。有設定時會優先使用，比關鍵字搜尋更精準。"
              },
              "confirmation": {
                "type": "object",
                "required": ["code"],
                "description": "訂房確認資訊 (選填)。設定後飯店卡會顯示確認碼 chip，點一下複製，並可放大出示給櫃台。",
                "properties": {
                  "code": {
                    "type": "string",
                    "description": "訂房確認碼/訂單編號。純數字代碼請加引號 (例如 '012345')，避免被解析成數字而遺失前導零。"
                  },
                  "name": {
                    "type": "string",
                    "description": "訂位人姓名 (選填)，建議與護照拼音一致。"
                  },
                  "note": {
                    "type": "string",
                    "description": "補充備註 (選填)，例如「入住時出示護照」。"
                  }
                }
              }
            }
          }
        }
      }
    },
    "todo": {
      "type": "array",
      "description": "行前待辦清單",
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "description": "待辦事項文字"
          },
          "checked": {
            "type": "boolean",
            "description": "預設是否已勾選 (選填，預設 false)"
          }
        }
      }
    },
    "packing": {
      "type": "array",
      "description": "隨身行李與打包清單",
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "description": "打包物品描述"
          },
          "checked": {
            "type": "boolean",
            "description": "預設是否已勾選 (選填，預設 false)"
          }
        }
      }
    },
    "days": {
      "type": "array",
      "description": "每日行程細節列表",
      "items": {
        "type": "object",
        "required": ["day", "date", "region", "pace", "timeline"],
        "properties": {
          "day": {
            "type": "integer",
            "description": "第幾天，例如 1"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "當天日期 (YYYY-MM-DD)"
          },
          "region": {
            "type": "string",
            "description": "主要活動區域/景點，例如: 新宿、明洞"
          },
          "city": {
            "type": "string",
            "description": "當日所在城市，覆蓋 trip.city 的天氣查詢 (選填，多城市行程用)。建議使用英文名稱 (例如: Kyoto)，可加兩碼國碼後綴消歧 (例如: 'Springfield, US')。留空字串視同未設定，回退至 trip.city。"
          },
          "pace": {
            "type": "string",
            "description": "今日行程節奏描述，例如: 慢活、需要早起"
          },
          "timeline": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["time", "title", "type", "desc"],
              "properties": {
                "time": {
                  "type": "string",
                  "description": "時間區間，例如: 14:00 - 15:30"
                },
                "title": {
                  "type": "string",
                  "description": "行程或事件標題"
                },
                "type": {
                  "type": "string",
                  "enum": ["booked", "must-go", "standard", "option"],
                  "description": "事件類型：booked(預訂/橘色), must-go(必訪/粉色), standard(一般/藍色), option(備選/紫色)"
                },
                "desc": {
                  "type": "string",
                  "description": "詳細說明描述"
                },
                "status": {
                  "type": "string",
                  "enum": ["done", "skipped"],
                  "description": "打卡狀態 (選填)：done=已完成, skipped=略過。未設定表示尚未造訪。通常由 App 內的打卡按鈕寫入，並隨 YAML 與分享連結保留進度。"
                },
                "bullets": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "備註條列式項目 (支援 HTML 標籤如 <i>)"
                },
                "localName": {
                  "type": "string",
                  "description": "地點的當地語言名稱，作為地圖搜尋關鍵字 (點擊按鈕開啟地圖/複製)"
                },
                "mapLink": {
                  "type": "string",
                  "description": "地圖直接連結 (如 naver.me / maps.app.goo.gl 短網址)。有設定時會優先使用，比關鍵字搜尋更精準。"
                },
                "confirmation": {
                  "type": "object",
                  "required": ["code"],
                  "description": "訂位確認資訊 (選填，通常用於 booked 事件)。設定後事件卡會顯示確認碼 chip，點一下複製，並可放大出示給櫃台。",
                  "properties": {
                    "code": {
                      "type": "string",
                      "description": "訂位確認碼/訂單編號。純數字代碼請加引號 (例如 '012345')，避免被解析成數字而遺失前導零。"
                    },
                    "name": {
                      "type": "string",
                      "description": "訂位人姓名 (選填)，建議與護照拼音一致。"
                    },
                    "note": {
                      "type": "string",
                      "description": "補充備註 (選填)，例如「報到時出示護照」。"
                    }
                  }
                },
                "links": {
                  "type": "array",
                  "description": "同一事件的補充連結 (選填)，例如官網、攻略文，或同一行程想放的多個點。地圖連結會自動顯示對應的品牌 icon。若是「擇一前往」的備選地點 (如備案餐廳)，請改用 alternatives。",
                  "items": {
                    "type": "object",
                    "required": ["label", "url"],
                    "properties": {
                      "label": {
                        "type": "string",
                        "description": "連結顯示文字"
                      },
                      "url": {
                        "type": "string",
                        "description": "連結網址"
                      }
                    }
                  }
                },
                "alternatives": {
                  "type": "array",
                  "description": "備選地點清單 (選填)，例如備案餐廳：每筆是一個候選地點，含當地語言店名 (可放大出示問路) 與備註 (如「排隊超過 30 分鐘就換」)，供現場換點決策。在事件卡尾端以折疊清單顯示。若只是同一事件的補充連結或多個點，請改用 links。",
                  "items": {
                    "type": "object",
                    "required": ["title"],
                    "properties": {
                      "title": {
                        "type": "string",
                        "description": "備選地點名稱"
                      },
                      "localName": {
                        "type": "string",
                        "description": "地點的當地語言名稱 (選填)，可放大出示問路，也作為地圖搜尋關鍵字"
                      },
                      "mapLink": {
                        "type": "string",
                        "description": "地圖直接連結 (選填，如 naver.me / maps.app.goo.gl 短網址)。有設定時會優先使用，比關鍵字搜尋更精準。"
                      },
                      "note": {
                        "type": "string",
                        "description": "換點決策備註 (選填)，例如「排隊超過 30 分鐘就換」。"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
