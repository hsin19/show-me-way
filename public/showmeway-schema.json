{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "下面一way 行程 Schema",
  "type": "object",
  "required": ["trip", "days"],
  "properties": {
    "trip": {
      "type": "object",
      "required": ["name", "start", "end", "departure", "hotels"],
      "properties": {
        "name": {
          "type": "string",
          "description": "行程名稱"
        },
        "start": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "出發日期 (YYYY-MM-DD 格式，例如: 2026-06-11)"
        },
        "end": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "回程日期 (YYYY-MM-DD 格式，例如: 2026-06-16)"
        },
        "departure": {
          "type": "string",
          "description": "去程班機起飛時間，ISO 8601 格式，例如: 2026-06-11T14:00:00+08:00 (用於首頁倒數計時)"
        },
        "lang": {
          "type": "string",
          "enum": ["ko", "ja", "en"],
          "description": "目的地語言代碼，用於選擇內建的實用常用語與計程車司機提示 (ko=韓文, ja=日文, en=英文)。未設定或不支援時預設為英文 (en)。"
        },
        "currency": {
          "type": "string",
          "description": "目的地貨幣代碼，例如: KRW, JPY, USD (選填，未設定時將自動依目的地語言或預設推導)"
        },
        "mapProvider": {
          "type": "string",
          "enum": ["naver", "google"],
          "description": "地圖搜尋使用的服務 (選填)。韓國因地圖法規建議設 naver，未設定時預設使用 Google Maps。"
        },
        "city": {
          "type": "string",
          "description": "目的地城市，用於查詢每日天氣預報 (選填，未設定或留空字串時不顯示天氣)。請使用英文名稱 (例如: Tokyo, Seoul, Osaka)，中文名稱常查不到或比對到錯誤國家。可在個別 day 以 city 覆蓋 (多城市行程)。"
        },
        "wallets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "記帳使用的自訂電子錢包/卡片清單 (例如: Suica, WOWPASS, 信用卡。現金預設會自動存在)"
        },
        "hotels": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "address", "checkIn", "checkOut"],
            "properties": {
              "name": {
                "type": "string",
                "description": "飯店/旅宿名稱"
              },
              "address": {
                "type": "string",
                "description": "飯店外文地址 (供計程車司機觀看/複製)"
              },
              "checkIn": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                "description": "入住日期 (YYYY-MM-DD)"
              },
              "checkOut": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                "description": "退房日期 (YYYY-MM-DD)"
              },
              "localName": {
                "type": "string",
                "description": "地點的當地語言名稱，作為地圖搜尋關鍵字 (點擊按鈕開啟地圖/複製)"
              },
              "mapLink": {
                "type": "string",
                "description": "地圖直接連結 (如 naver.me / maps.app.goo.gl 短網址)。有設定時會優先使用，比關鍵字搜尋更精準。"
              }
            }
          }
        }
      }
    },
    "todo": {
      "type": "array",
      "description": "行前待辦清單",
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "description": "待辦事項文字"
          },
          "checked": {
            "type": "boolean",
            "description": "預設是否已勾選 (選填，預設 false)"
          }
        }
      }
    },
    "packing": {
      "type": "array",
      "description": "隨身行李與打包清單",
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "description": "打包物品描述"
          },
          "checked": {
            "type": "boolean",
            "description": "預設是否已勾選 (選填，預設 false)"
          }
        }
      }
    },
    "days": {
      "type": "array",
      "description": "每日行程細節列表",
      "items": {
        "type": "object",
        "required": ["day", "date", "region", "pace", "timeline"],
        "properties": {
          "day": {
            "type": "integer",
            "description": "第幾天，例如 1"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "當天日期 (YYYY-MM-DD)"
          },
          "region": {
            "type": "string",
            "description": "主要活動區域/景點，例如: 新宿、明洞"
          },
          "city": {
            "type": "string",
            "description": "當日所在城市，覆蓋 trip.city 的天氣查詢 (選填，多城市行程用)。請使用英文名稱 (例如: Kyoto)。留空字串視同未設定，回退至 trip.city。"
          },
          "pace": {
            "type": "string",
            "description": "今日行程節奏描述，例如: 慢活、需要早起"
          },
          "timeline": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["time", "title", "type", "desc"],
              "properties": {
                "time": {
                  "type": "string",
                  "description": "時間區間，例如: 14:00 - 15:30"
                },
                "title": {
                  "type": "string",
                  "description": "行程或事件標題"
                },
                "type": {
                  "type": "string",
                  "enum": ["booked", "must-go", "standard", "option"],
                  "description": "事件類型：booked(預訂/橘色), must-go(必訪/粉色), standard(一般/藍色), option(備選/紫色)"
                },
                "desc": {
                  "type": "string",
                  "description": "詳細說明描述"
                },
                "bullets": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "備註條列式項目 (支援 HTML 標籤如 <i>)"
                },
                "localName": {
                  "type": "string",
                  "description": "地點的當地語言名稱，作為地圖搜尋關鍵字 (點擊按鈕開啟地圖/複製)"
                },
                "mapLink": {
                  "type": "string",
                  "description": "地圖直接連結 (如 naver.me / maps.app.goo.gl 短網址)。有設定時會優先使用，比關鍵字搜尋更精準。"
                },
                "links": {
                  "type": "array",
                  "description": "額外的具名連結 (例如一個行程想放多個點)。地圖連結會自動顯示對應的品牌 icon。",
                  "items": {
                    "type": "object",
                    "required": ["label", "url"],
                    "properties": {
                      "label": {
                        "type": "string",
                        "description": "連結顯示文字"
                      },
                      "url": {
                        "type": "string",
                        "description": "連結網址"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
