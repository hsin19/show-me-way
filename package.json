{
  "name": "show-me-way",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "typecheck:fast": "node -e \"fs.rmSync('.svelte-check',{recursive:true,force:true})\" && svelte-check --tsgo --tsconfig ./tsconfig.app.json && tsgo -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm run format && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "check:ci": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*": "dprint fmt --allow-no-files",
    "*.{js,ts,svelte}": "eslint --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lucide/svelte": "^1.17.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.3",
    "@typescript/native-preview": "7.0.0-dev.20260610.1",
    "@vite-pwa/assets-generator": "^1.0.2",
    "dprint": "^0.54.0",
    "eslint": "^10.5.0",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "js-yaml": "^4.2.0",
    "lint-staged": "^17.0.7",
    "simple-git-hooks": "^2.13.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "svelte-eslint-parser": "^1.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7",
    "workbox-window": "^7.4.1"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-tc": "^5.2.10",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8"
  }
}
